const OWNER_NAME = env.OWNER_NAME || "SKY FLOREX 🪐";
const SUPPORT_CONTACT = env.SUPPORT_CONTACT || "@LazyMikey";
const STORE_NAME = env.STORE_NAME || "FLOREXIA 🍡";
const REFERRAL_BONUS = 1;
const NUMBERS_MARKUP = 30;

// ========== RATE LIMITING ==========
const RATE_LIMIT = 30;
const rateLimit = {};

function checkRateLimit(userId) {
    const now = Date.now() / 1000;
    if (!rateLimit[userId]) rateLimit[userId] = [];
    rateLimit[userId] = rateLimit[userId].filter(t => now - t < 60);
    if (rateLimit[userId].length >= RATE_LIMIT) return false;
    rateLimit[userId].push(now);
    return true;
}

// ========== DATABASE INIT ==========
const db = new Database('florexia');

// Users table
db.run(`
    CREATE TABLE IF NOT EXISTS users (
        user_id INTEGER PRIMARY KEY,
        username TEXT,
        first_name TEXT,
        balance INTEGER DEFAULT 2,
        is_blocked INTEGER DEFAULT 0,
        is_admin INTEGER DEFAULT 0,
        referred_by INTEGER,
        referral_code TEXT UNIQUE,
        joined_date TIMESTAMP DEFAULT CURRENT_TIMESTAMP
    )
`);

// Orders table
db.run(`
    CREATE TABLE IF NOT EXISTS orders (
        order_id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER,
        service_type TEXT,
        platform TEXT,
        country TEXT,
        link TEXT,
        quantity INTEGER,
        final_price INTEGER,
        api_order_id TEXT,
        number TEXT,
        status TEXT DEFAULT 'pending',
        completed_by INTEGER,
        completed_at TIMESTAMP,
        created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
    )
`);

// Payments table
db.run(`
    CREATE TABLE IF NOT EXISTS payments (
        payment_id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER,
        amount INTEGER,
        requested_amount INTEGER,
        transaction_id TEXT,
        screenshot_file_id TEXT,
        status TEXT DEFAULT 'pending',
        approved_by INTEGER,
        approved_at TIMESTAMP,
        created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
    )
`);

// Referrals table
db.run(`
    CREATE TABLE IF NOT EXISTS referrals (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        referrer_id INTEGER,
        referred_id INTEGER UNIQUE,
        bonus INTEGER,
        created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
    )
`);

// Config table
db.run(`
    CREATE TABLE IF NOT EXISTS config (
        key TEXT PRIMARY KEY,
        value TEXT
    )
`);

